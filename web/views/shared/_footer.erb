<% slim = defined?(slim) && slim
   footer_static_pages = defined?(static_pages) && static_pages ? static_pages : []
   footer_view_mode = defined?(current_view_mode) && current_view_mode ? current_view_mode.to_s : "" %>
<footer class="app-footer<%= slim ? " app-footer--slim" : "" %>">
  <div class="footer-content">
    <span class="footer-brand">PotatoMesh</span>
    <% if version && !version.empty? %>
      <span class="mono"><%= version %></span>
    <% end %>
    <span class="footer-separator" aria-hidden="true">—</span>
    <span class="footer-links">
      <%# Static operator pages live in the footer tier (SPEC UX11): the
          primary nav carries only the product views. %>
      <% footer_static_pages.each do |sp| %>
        <% sp_active = footer_view_mode == "page_#{sp.slug}" %>
        <a href="/pages/<%= Rack::Utils.escape_path(sp.slug) %>"<%= sp_active ? ' aria-current="page"' : "" %>><%= Rack::Utils.escape_html(sp.title) %></a>
        <span class="footer-separator" aria-hidden="true">—</span>
      <% end %>
      GitHub:
      <a href="https://github.com/l5yth/potato-mesh" target="_blank">l5yth/potato-mesh</a>
      <% if contact_link && !contact_link.empty? %>
        <span class="footer-separator" aria-hidden="true">—</span>
        <span class="footer-contact">
          <%= site_name %> chat:
          <% if contact_link_url %>
            <a href="<%= contact_link_url %>" target="_blank"><%= contact_link %></a>
          <% else %>
            <%= contact_link %>
          <% end %>
        </span>
      <% end %>
    </span>
  </div>
</footer>
